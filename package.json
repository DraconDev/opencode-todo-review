{
  "name": "opencode-todo-review",
  "version": "1.0.4",
  "description": "Auto-detect when all session todos are completed and trigger a review. Yin to opencode-todo-reminder's yang.",
  "website": "https://dracon.uk",
  "type": "module",
  "main": "opencode-auto-review-completed-todos.js",
  "types": "opencode-auto-review-completed-todos.ts",
  "scripts": {
    "build": "bun build opencode-auto-review-completed-todos.ts --outdir=. --format=esm --sourcemap",
    "typecheck": "bun tsc --noEmit",
    "test": "bun test",
    "verify": "bun run build && git diff --exit-code opencode-auto-review-completed-todos.js",
    "precommit": "bun run verify"
  },
  "files": [
    "opencode-auto-review-completed-todos.js",
    "opencode-auto-review-completed-todos.ts",
    "README.md"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0",
    "@opencode-ai/sdk": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": ">=1.0.0",
    "@opencode-ai/sdk": ">=1.0.0",
    "@types/node": ">=20"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "todo",
    "review",
    "productivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DraconDev/opencode-auto-review-completed-todos"
  },
  "engines": {
    "node": ">=20"
  }
}